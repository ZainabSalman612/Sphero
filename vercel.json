{
  "version": 2,
  "name": "sphero",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/py/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/api/v1/search",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/api/v1/health",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}